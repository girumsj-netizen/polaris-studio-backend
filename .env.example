# â”€â”€ Polaris Studio Backend Environment Variables â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

# Server port (Render sets this automatically via PORT env var)
PORT=3001

# Frontend URLs allowed to make CORS requests (comma-separated in code, one per line here)
FRONTEND_URL=https://your-app.vercel.app
FRONTEND_URL_LOCAL=http://localhost:4321

# Email service (Gmail SMTP with App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
CONTACT_EMAIL=polarisdigitalorg@gmail.com
